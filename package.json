{
	"name": "epiq",
	"version": "0.1.3",
	"license": "MIT",
	"type": "module",
	"description": "EPIQ - CLI based issue tracker",
	"bin": {
		"epiq": "dist/cli.js"
	},
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
		"build": "tsc --noEmit",
		"build:publish": "pnpm clean && esbuild source/cli.tsx --bundle --platform=node --format=esm --target=node16 --minify --outfile=dist/cli.js --banner:js='#!/usr/bin/env node' --external:react-devtools-core",
		"dev": "tsc --watch --noEmit",
		"dev:start": "IS_LOCAL=true tsx source/cli.tsx",
		"start": "node dist/cli.js",
		"start:debug": "IS_LOCAL=true node dist/cli.js",
		"test": "prettier --check \"**/*.{ts,tsx}\" && vitest run",
		"prepack": "pnpm build:publish",
		"pack:check": "rm -f epiq-*.tgz && npm pack --json",
		"publish:tarball": "FILE=$(ls -t epiq-*.tgz | head -n 1) && echo \"Publishing $FILE\" && npm publish \"$FILE\"",
		"publish:dry": "rm -f epiq-*.tgz && npm pack && FILE=$(ls -t epiq-*.tgz | head -n 1) && npm publish --dry-run \"$FILE\"",
		"release": "pnpm test && pnpm pack:check && pnpm publish:tarball"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"ink": "^6.8.0",
		"json-stringify-pretty-compact": "^4.0.0",
		"marked": "^17.0.3",
		"marked-terminal": "^7.3.0",
		"meow": "^14.1.0",
		"react": "^19.2.4",
		"ulid": "^3.0.2"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/marked-terminal": "^6.1.1",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"chalk": "^5.2.0",
		"esbuild": "^0.25.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"tsx": "^4.20.3",
		"typescript": "^5.0.3",
		"vitest": "^4.1.0",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
